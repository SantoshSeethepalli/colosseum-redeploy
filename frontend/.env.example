# ==========================================
# FRONTEND CONFIGURATION EXAMPLE (.env.example)
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# ==========================================

# --- Environment Setup ---
NODE_ENV=development

# --- Backend APIs (Localhost) ---
NEXT_PUBLIC_API_URL=http://localhost:5002
NEXT_PUBLIC_BACKEND_URL=http://localhost:5002
NEXT_PUBLIC_API_BASE_URL=http://localhost:5002

# --- Authentication & Security ---
# Ensure this exactly matches the backend secret
JWT_SECRET_KEY=your_secure_random_jwt_key_here
NEXT_PUBLIC_JWT_SECRET=your_secure_random_jwt_key_here

# --- External APIs ---
# Stripe Public Key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_public_stripe_key_here

# --- Cross-Origin Resource Sharing (CORS) ---
FRONTEND_URL=http://localhost:3000
